{
  "name": "alemonjs-yunzai",
  "version": "1.0.0-rc.0",
  "description": "yunzai-bot",
  "author": "ningmengchongshui",
  "type": "module",
  "main": "./lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./package": "./package.json"
  },
  "scripts": {
    "app": "node index.js",
    "dev": "npx lvy app.ts",
    "view": "npx lvy app.ts --jsxp",
    "build": "lvy build",
    "lint": "eslint src --ext .ts,.tsx,.js --max-warnings=0",
    "lint:fix": "eslint src --ext .ts,.tsx,.js --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "jsxp": "^1.3.0",
    "markdown-to-jsx": "^9.7.13",
    "md5": "^2.3.0"
  },
  "devDependencies": {
    "@alemonjs/bubble": "^2.1.7",
    "@alemonjs/db": "^0.0.16",
    "@alemonjs/discord": "^2.1.10",
    "@alemonjs/onebot": "^2.1.11",
    "@alemonjs/qq-bot": "^2.1.11",
    "@eslint/js": "^9.18.0",
    "alemonjs": "^2.1.48",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.3",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "lvyjs": "0.3.0-alpha.2",
    "prettier": "^3",
    "sass": "^1.90.0",
    "tailwindcss": "3",
    "typescript-eslint": "^8.19.1"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{json,md,yml,yaml,css,scss,html}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@1.22.22",
  "keywords": [
    "alemonjs"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "bugs": "https://github.com/xiuxianjs/alemonjs-yunzai/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiuxianjs/alemonjs-yunzai.git"
  }
}
