{
  "name": "alemonjs-yunzai",
  "version": "0.0.1",
  "description": "yunzai-bot",
  "author": "ningmengchongshui",
  "type": "module",
  "main": "./lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./package": "./package.json"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "jsxp": "^1.3.0",
    "markdown-to-jsx": "^9.7.13",
    "md5": "^2.3.0"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{json,md,yml,yaml,css,scss,html}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@1.22.22",
  "keywords": [
    "alemonjs"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "bugs": "https://github.com/xiuxianjs/alemonjs-yunzai/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiuxianjs/alemonjs-yunzai.git"
  }
}
